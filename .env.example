# Path to your Obsidian vault
VAULT_PATH=/path/to/your/ObsidianVault

# Path to the SQLite database (stored alongside vault, will be created if it doesn't exist)
DB_PATH=/path/to/your/ObsidianVault/.onevault-mcp/vault.db

# Directories to exclude from indexing (comma-separated, relative to vault root)
EXCLUDE_DIRS=.obsidian,.trash
