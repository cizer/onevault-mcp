# Path to your Markdown corpus, such as an Obsidian vault or docs repo
VAULT_PATH=/path/to/your/MarkdownCorpus

# Path to the SQLite database (will be created if it doesn't exist)
DB_PATH=/path/to/your/MarkdownCorpus/.onevault-mcp/corpus.db

# Directories to exclude from indexing (comma-separated, relative to corpus root)
EXCLUDE_DIRS=.obsidian,.trash
